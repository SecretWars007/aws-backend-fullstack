# AWS Secrets Manager ARN for the PostgreSQL database
DB_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:yape-bcp/db-credentials
DB_HOST=yape-bcp-db.cluster-xxxxxxxx.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=yapebcp
DB_USER=yapebcpuser

# Cognito
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_REGION=us-east-1

# JWT signing (internal device tokens)
JWT_SECRET=change-me-in-production

# General
STAGE=local
AWS_REGION=us-east-1
